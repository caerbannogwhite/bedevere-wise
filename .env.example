# Copy this file to `.env.local` and fill in values for local development.
# Vite inlines any VITE_*-prefixed var into the bundle at build time.

# Base URL of the deployed feedback worker. Empty / unset → the in-app
# Feedback form falls back to opening a mailto: link.
# Local-dev example (with `bun run dev` in cloudflare/feedback-worker/):
#   VITE_FEEDBACK_URL=http://localhost:8787
VITE_FEEDBACK_URL=

# Source URL for the stats_duck (ggsql VISUALIZE) DuckDB extension. Can be
# absolute (default: the published GitHub Pages repo) or page-relative
# (the runtime prefixes window.location.origin).
#
# To point at a local build during development:
#   1. mklink /J public\extensions\stats-duck \
#        C:\path\to\the-stats-duck\build\wasm_eh\repository
#      (Windows; on macOS/Linux: ln -s for the same effect)
#   2. Set VITE_STATS_DUCK_URL=/extensions/stats-duck below.
#
# public/extensions/ is gitignored, so the junction/symlink stays local.
VITE_STATS_DUCK_URL=
